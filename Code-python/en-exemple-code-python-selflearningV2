import gymnasium as gym
import numpy as np
from stable_baselines3 import SAC
from stable_baselines3.common.vec_env import DummyVecEnv
import matplotlib
matplotlib.use('Agg') 
import matplotlib.pyplot as plt
import os
import sys
from collections import deque

# --- MRCC V17 CONFIGURATION: RECIPROCAL COUPLING ---
# Here, the "Track" is a physical entity that reacts to the Agent.
# The Agent is no longer passive. It is the artisan of its environment.

TRACK_SPEED = 0.03       
TRACK_FREQUENCY = 0.08     
ENV_NOISE = 0.0005         

# Coupling Parameters
COUPLING_STRENGTH = 0.5    # Mutual attraction strength (Agent <-> Track)
TRACK_INERTIA = 0.95       # Track inertia (it resists change)
AGENT_INERTIA = 0.95       # Agent inertia

MODEL_PATH = "mrcc_coupled_v17.zip"
OUTPUT_IMAGE = "resultats_mrcc_coupled_v17.png"

class MRCCEnvironment(gym.Env):
    metadata = {'render_modes': ['human']}
    
    def __init__(self):
        super().__init__()
        self.action_space = gym.spaces.Box(low=-1.0, high=1.0, shape=(1,), dtype=np.float32)
        # Observation: [x_agent, vx_agent, x_track, vx_track, distance]
        self.observation_space = gym.spaces.Box(low=-20.0, high=20.0, shape=(5,), dtype=np.float32)
        self.reset()

    def reset(self, seed=None, options=None):
        super().reset(seed=seed)
        # Initial Agent position
        self.x_agent = 0.0
        self.vx_agent = 0.0
        
        # Initial Track position (now a dynamic entity)
        # It starts with a tendency to oscillate
        self.x_track = 0.0
        self.vx_track = 0.0
        self.angle = 0.0 # For the track's oscillatory tendency
        
        self.frame_count = 0
        return self._get_obs(), {}

    def _get_obs(self):
        distance = self.x_agent - self.x_track
        return np.array([
            float(self.x_agent),
            float(self.vx_agent),
            float(self.x_track),
            float(self.vx_track),
            float(distance)
        ], dtype=np.float32)

    def step(self, action):
        self.frame_count += 1
        action_val = action if isinstance(action, np.ndarray) else np.array([action])
        action_scalar = float(action_val.item())

        # --- 1. CAUSE IS DYNAMIC (The Track Reacts) ---
        # The track has a natural tendency to oscillate (like a wave)
        # But this oscillation is modified by the Agent's presence (coupling)
        
        # Natural track force (base sine wave)
        natural_force_track = np.cos(self.angle) * TRACK_FREQUENCY * 1.5
        
        # Coupling force: The track is attracted to the Agent
        # If the Agent is far, the track "pulls" towards it (or vice versa)
        coupling_force_track = (self.x_agent - self.x_track) * COUPLING_STRENGTH
        
        # Update track velocity
        # The track has inertia (TRACK_INERTIA)
        self.vx_track *= TRACK_INERTIA
        self.vx_track += natural_force_track * 0.1 # Natural oscillation is gentle
        self.vx_track += coupling_force_track * 0.1 # Reaction to the Agent is weak but present
        
        # Limit track velocity
        self.vx_track = np.clip(self.vx_track, -2.0, 2.0)
        self.x_track += self.vx_track
        
        # Update angle for oscillation
        self.angle += TRACK_SPEED

        # --- 2. THE AGENT IS THE ARTISAN (It acts on the coupling) ---
        # The Agent does not just suffer the track. It modulates the attraction.
        # Positive action = Increases attraction (it "pulls" the track towards it)
        # Negative action = Reduces attraction (it "releases" the track)
        
        # Coupling force on the Agent (Newton's reaction: action = -reaction)
        coupling_force_agent = -(self.x_track - self.x_agent) * COUPLING_STRENGTH
        
        # The Agent modulates this force with its action
        # If action = 1, it amplifies coupling (it wants to follow the track)
        # If action = -1, it cancels coupling (it isolates itself)
        modulation = 1.0 + action_scalar # From 0 to 2
        
        total_coupling = coupling_force_agent * modulation
        
        # Agent inertia force
        self.vx_agent *= AGENT_INERTIA
        self.vx_agent += total_coupling
        self.vx_agent += np.random.normal(0, ENV_NOISE)
        
        self.vx_agent = np.clip(self.vx_agent, -5.0, 5.0)
        self.x_agent += self.vx_agent

        # --- 3. DISSONANCE AND REWARD ---
        # Dissonance is the distance between the Agent and the Track
        # But also the difference in velocity (synchronization)
        dist_error = self.x_agent - self.x_track
        vel_error = self.vx_agent - self.vx_track
        
        # Total Dissonance (Free Energy)
        dissonance = (dist_error ** 2) + (vel_error ** 2)
        
        # Reward: Minimize dissonance
        reward = -dissonance
        
        # Action cost (modulation effort costs energy)
        reward -= (action_scalar ** 2) * 0.05

        return self._get_obs(), reward, False, False, {}

def train_agent():
    print(">>> STARTING TRAINING (V17 MODE - RECIPROCAL COUPLING)...")
    print("The Agent and the Track interact mutually. The Agent is the artisan of its environment.")
    
    env = DummyVecEnv([lambda: MRCCEnvironment()])
    
    model = SAC(
        "MlpPolicy", 
        env, 
        verbose=0, 
        learning_rate=1e-3, 
        buffer_size=500000, 
        batch_size=256, 
        gamma=0.99, 
        tau=0.005,
        train_freq=4,
        gradient_steps=1
    )
    
    total_timesteps = 200000 
    report_interval = 5000 
    
    print(f"Training for {total_timesteps} steps...")
    
    reward_buffer = deque(maxlen=1000)
    error_buffer = deque(maxlen=1000)
    
    result = env.reset()
    obs = result if isinstance(result, tuple) else result
    
    step_count = 0
    stuck_counter = 0
    
    while step_count < total_timesteps:
        if step_count < 30000:
            action = env.action_space.sample()
        else:
            action, _ = model.predict(obs, deterministic=False)
            
        result = env.step(action)
        if len(result) == 5:
            obs, reward, terminated, truncated, info = result
        else:
            obs, reward, done, info = result
            terminated, truncated = done, done
        
        # Correct extraction
        dist_error = float(obs[0, 4])
        
        if len(error_buffer) > 10:
            last_errors = list(error_buffer)[-10:]
            if max(last_errors) - min(last_errors) < 0.01 and abs(dist_error) > 1.0:
                stuck_counter += 1
                if stuck_counter > 50:
                    print(f"WARNING: Agent stuck at error={dist_error:.2f}. Forced reset.")
                    result = env.reset()
                    obs = result if isinstance(result, tuple) else result
                    stuck_counter = 0
                    continue
            else:
                stuck_counter = 0
        
        reward_buffer.append(float(reward.item()))
        error_buffer.append(dist_error)
        
        step_count += 1
        
        if step_count % report_interval == 0:
            avg_reward = np.mean(reward_buffer)
            avg_error = np.mean(error_buffer)
            avg_var = np.var(list(error_buffer)[-50:]) if len(error_buffer) > 50 else 0.0
            
            print(f"\n{'='*60}")
            print(f"STATISTICS AT STEP {step_count}")
            print(f"{'='*60}")
            print(f"{'Average Reward':<35} | {avg_reward:>20.4f}")
            print(f"{'Average Distance Error':<35} | {avg_error:>20.4f}")
            print(f"{'Variance':<35} | {avg_var:>20.4f}")
            print(f"{'='*60}\n")

    model.save(MODEL_PATH)
    print(f">>> Model saved: {MODEL_PATH}")
    return model

def simulate_and_plot(model):
    env = DummyVecEnv([lambda: MRCCEnvironment()])
    result = env.reset()
    obs = result if isinstance(result, tuple) else result
    rewards, positions_agent, positions_track = [], [], []
    
    print("Running simulation (2000 steps)...")
    
    for i in range(2000):
        action, _ = model.predict(obs, deterministic=True)
        result = env.step(action)
        if len(result) == 5: obs, reward, terminated, truncated, info = result
        else: obs, reward, done, info = result; terminated, truncated = done, done
        
        rewards.append(reward)
        positions_agent.append(float(env.envs.x_agent))
        positions_track.append(float(env.envs.x_track))

    rewards_clean = [float(r) for r in rewards]
    pos_agent = [float(p) for p in positions_agent]
    pos_track = [float(p) for p in positions_track]
    
    plt.figure(figsize=(14, 6))
    
    plt.subplot(1, 2, 1)
    plt.plot(rewards_clean, label='Reward', color='blue', alpha=0.6)
    if len(rewards_clean) > 20:
        smoothed = np.convolve(rewards_clean, np.ones(20)/20, mode='valid')
        plt.plot(range(len(smoothed)), smoothed, label='Moving Average', color='red', linewidth=2)
    plt.title('Reward: Reciprocal Coupling')
    plt.xlabel('Frames'); plt.ylabel('Reward'); plt.legend(); plt.grid(True, alpha=0.3)

    plt.subplot(1, 2, 2)
    plt.plot(pos_agent, label='Agent', color='green', alpha=0.7)
    plt.plot(pos_track, label='Track (Dynamic Entity)', color='orange', linestyle='--', alpha=0.7)
    plt.title('Trajectory: Mutual Interaction')
    plt.xlabel('Frames'); plt.ylabel('Position X'); plt.legend(); plt.grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.savefig(OUTPUT_IMAGE, dpi=150)
    plt.close()
    print(f"Graph saved: {OUTPUT_IMAGE}")

if __name__ == "__main__":
    model_exists = os.path.exists(MODEL_PATH) or os.path.exists(f"{MODEL_PATH}.zip")
    if not model_exists:
        model = train_agent()
    else:
        try:
            model = SAC.load(MODEL_PATH)
            print("Model loaded. Resuming training...")
        except:
            model = train_agent()
    simulate_and_plot(model)
